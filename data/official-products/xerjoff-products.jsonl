{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/1888-eau-de-parfum", "product_name": "1888", "collection": "New Arrivals", "description": "1888 by Casamorati is a timeless, woody-amber scent that tells a story of Italian craftsmanship and the pursuit of excellence. With its comforting warmth, mild spiciness and subtle animalic accent, 1888 pays homage to Tuscany\u2019s historic tradition of leather tanning. A slow, deliberate process that \u2014 much like the art of perfumery itself \u2014 uses the finest natural ingredients to create something that\u2019s truly worth cherishing.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml", "30 ml"], "price_text": "USD 270.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260503T154502Z", "raw_html_path": "data/raw/xerjoff/20260503T154502Z/1888-eau-de-parfum.json", "source_status": "ok", "source_id": "7403757961306", "match_hint": "Xerjoff 1888", "extra": {"handle": "1888-eau-de-parfum", "tags": ["Amber", "Cloves", "Coriander", "Green Pepper", "Mysore Sandalwood", "Patchouli", "Ylang-Ylang"], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-1888-eau-de-parfum-100ml.png?v=1744795659", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-1888-still.jpg?v=1744795659"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/bouquet-ideale-eau-de-parfum", "product_name": "Bouquet Ideale", "collection": "New Arrivals", "description": "Bouquet Ideale traces the origins of the original Casamorati perfume house, building an olfactory bridge between the past and the present. Based on a perfume originally released by Casamorati in the 19th century, Bouquet Ideale is the outcome of an ambitious challenge that Xerjoff founder Sergio Momo set himself. Upon discovering a sample of the original perfume, which had a largely floral composition, he endeavoured to recreate the scent without using any floral notes. This warm, soothing scent is a marriage between old and new, and a testament to the art of perfumery.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml", "30 ml"], "price_text": "USD 270.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260503T154502Z", "raw_html_path": "data/raw/xerjoff/20260503T154502Z/bouquet-ideale-eau-de-parfum.json", "source_status": "ok", "source_id": "7403759566938", "match_hint": "Xerjoff Bouquet Ideale", "extra": {"handle": "bouquet-ideale-eau-de-parfum", "tags": ["Cedarwood", "Cinnamon", "Coumarin", "Guaiac Wood", "Musk", "Nutmeg", "Tobacco Flowers", "Vanilla"], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-bouquetideale-eau-de-parfum-100ml.png?v=1744805690", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-bouquetideale-still.jpg?v=1744805690"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/casafutura-eau-de-parfum", "product_name": "Casafutura", "collection": "New Arrivals", "description": "Casafutura is a unique perfume that draws inspiration from the Futurist art movement. It seeks to do things differently, exemplified by the symbolic inclusion of diphylleia grayi in its composition. The white petals of this odourless flower turn completely transparent when wet, in what is a stunning display of beauty and a transformation beyond our usual expectations of the natural world. An artistic statement that represents both Futurism's desire for change and Xerjoff\u2019s philosophy of innovation.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml", "30 ml"], "price_text": "USD 270.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260503T154502Z", "raw_html_path": "data/raw/xerjoff/20260503T154502Z/casafutura-eau-de-parfum.json", "source_status": "ok", "source_id": "7403758583898", "match_hint": "Xerjoff Casafutura", "extra": {"handle": "casafutura-eau-de-parfum", "tags": ["Bergamot", "Cedarwood", "Diphylleia Grayi", "Eucalyptus", "Geranium", "Lavender", "Musk", "Patchouli", "Rose", "Rosemary", "Sandalwood"], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-casafutura-eau-de-parfum-100ml.png?v=1744964838", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-casafutura-still.jpg?v=1744964838"]}}
