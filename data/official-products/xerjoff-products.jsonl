{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/1888-eau-de-parfum", "product_name": "1888", "collection": "New Arrivals", "description": "1888 by Casamorati is a timeless, woody-amber scent that tells a story of Italian craftsmanship and the pursuit of excellence. With its comforting warmth, mild spiciness and subtle animalic accent, 1888 pays homage to Tuscany\u2019s historic tradition of leather tanning. A slow, deliberate process that \u2014 much like the art of perfumery itself \u2014 uses the finest natural ingredients to create something that\u2019s truly worth cherishing.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml", "30 ml"], "price_text": "USD 270.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/1888-eau-de-parfum.json", "source_status": "ok", "source_id": "7403757961306", "match_hint": "Xerjoff 1888", "extra": {"handle": "1888-eau-de-parfum", "tags": ["Amber", "Cloves", "Coriander", "Green Pepper", "Mysore Sandalwood", "Patchouli", "Ylang-Ylang"], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-1888-eau-de-parfum-100ml.png?v=1744795659", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-1888-still.jpg?v=1744795659"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/bouquet-ideale-eau-de-parfum", "product_name": "Bouquet Ideale", "collection": "New Arrivals", "description": "Bouquet Ideale traces the origins of the original Casamorati perfume house, building an olfactory bridge between the past and the present. Based on a perfume originally released by Casamorati in the 19th century, Bouquet Ideale is the outcome of an ambitious challenge that Xerjoff founder Sergio Momo set himself. Upon discovering a sample of the original perfume, which had a largely floral composition, he endeavoured to recreate the scent without using any floral notes. This warm, soothing scent is a marriage between old and new, and a testament to the art of perfumery.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml", "30 ml"], "price_text": "USD 270.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/bouquet-ideale-eau-de-parfum.json", "source_status": "ok", "source_id": "7403759566938", "match_hint": "Xerjoff Bouquet Ideale", "extra": {"handle": "bouquet-ideale-eau-de-parfum", "tags": ["Cedarwood", "Cinnamon", "Coumarin", "Guaiac Wood", "Musk", "Nutmeg", "Tobacco Flowers", "Vanilla"], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-bouquetideale-eau-de-parfum-100ml.png?v=1744805690", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-bouquetideale-still.jpg?v=1744805690"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/casafutura-eau-de-parfum", "product_name": "Casafutura", "collection": "New Arrivals", "description": "Casafutura is a unique perfume that draws inspiration from the Futurist art movement. It seeks to do things differently, exemplified by the symbolic inclusion of diphylleia grayi in its composition. The white petals of this odourless flower turn completely transparent when wet, in what is a stunning display of beauty and a transformation beyond our usual expectations of the natural world. An artistic statement that represents both Futurism's desire for change and Xerjoff\u2019s philosophy of innovation.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml", "30 ml"], "price_text": "USD 270.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/casafutura-eau-de-parfum.json", "source_status": "ok", "source_id": "7403758583898", "match_hint": "Xerjoff Casafutura", "extra": {"handle": "casafutura-eau-de-parfum", "tags": ["Bergamot", "Cedarwood", "Diphylleia Grayi", "Eucalyptus", "Geranium", "Lavender", "Musk", "Patchouli", "Rose", "Rosemary", "Sandalwood"], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-casafutura-eau-de-parfum-100ml.png?v=1744964838", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-casafutura-still.jpg?v=1744964838"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/coro-eau-de-parfum", "product_name": "Coro", "collection": "New Arrivals", "description": "Coro is a scent with an invigorating energy. Its vibe is that of an early riser, a go-getter who is ready to take on the world. Curtains drawn at dawn to bask in the glory of another new day, hikes to the summit and back before lunchtime. Its energising freshness is its defining feature, a result of its purposefully curated composition.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["50 ml", "100 ml"], "price_text": "USD 230.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/coro-eau-de-parfum.json", "source_status": "ok", "source_id": "7403758649434", "match_hint": "Xerjoff Coro", "extra": {"handle": "coro-eau-de-parfum", "tags": ["Amber", "Jasmine", "Mango", "Musk", "Orris", "Pineapple", "Sandalwood", "Tropical Fruits", "Vanilla"], "product_type": "Perfume", "vendor": "XJ", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-coro-eau-de-parfum-50ml-1.png?v=1762078049", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-coro-still.jpg?v=1762078049"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/dama-bianca-eau-de-parfum", "product_name": "Dama Bianca", "collection": "New Arrivals", "description": "An elegant scent belonging to the soft floral olfactory family, Dama Bianca evokes images of well-manicured garden blooming in springtime, as perfect, cotton-like clouds float gently across the sky above. Its wearer savours the dreamlike ambience it creates all day long, the envy of those in its wake who experience it only fleetingly.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml", "30 ml"], "price_text": "USD 270.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/dama-bianca-eau-de-parfum.json", "source_status": "ok", "source_id": "7403760517210", "match_hint": "Xerjoff Dama Bianca", "extra": {"handle": "dama-bianca-eau-de-parfum", "tags": ["Cedarwood", "Chinese Kumquats", "Egyptian Jasmine", "Lily of the Valley", "Lime", "White Musk"], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-damabianca-eau-de-parfum-100ml.png?v=1744874551", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-damabianca-still.jpg?v=1744874551"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/dolce-amalfi-eau-de-parfum", "product_name": "Dolce Amalfi", "collection": "New Arrivals", "description": "Dolce Amalfi interprets the stunning natural beauty and authentic, old world charm of the Amalfi Coast in scent form. Reminiscent of both the elegance of the Belle \u00c9poque \u2014 when the region was a dramatic destination for writers and artists in search of inspiration \u2014 and the indulgence of the 50s and 60s, when it became the pinnacle of luxury, attracting glamorous elites from around the world.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml", "30 ml"], "price_text": "USD 270.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/dolce-amalfi-eau-de-parfum.json", "source_status": "ok", "source_id": "7403760910426", "match_hint": "Xerjoff Dolce Amalfi", "extra": {"handle": "dolce-amalfi-eau-de-parfum", "tags": [], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-dolceamalfi-eau-de-parfum-100ml.png?v=1744964320", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-dolceamalfi-still.jpg?v=1744964320"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/fiero-eau-de-parfum", "product_name": "Fiero", "collection": "New Arrivals", "description": "Fiero is the olfactory embodiment of la sprezzatura italiana , the art of seeming effortlessly stylish and well-presented. It has a dignified air, nestled between elegance and nonchalance. From its green glass flacon to its classically structured notes, every aspect of Fiero paints a picture of class, refinement and good taste.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml", "30 ml"], "price_text": "USD 270.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/fiero-eau-de-parfum.json", "source_status": "ok", "source_id": "7403749343322", "match_hint": "Xerjoff Fiero", "extra": {"handle": "fiero-eau-de-parfum", "tags": ["Bergamot", "Blood Orange", "Calabrian Lemon", "Coumarin", "Lemongrass", "Mint", "Mysore Sandalwood", "Neroli", "Patchouli", "Vetiver"], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-fiero-eau-de-parfum-100ml.png?v=1744970133", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-fiero-still.jpg?v=1744970133"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/fiore-dulivo-eau-de-parfum", "product_name": "Fiore D\u2019ulivo", "collection": "New Arrivals", "description": "A modern-day incarnation of a perfume initially released by Casamorati in the late 1800s, the composition of Fiore d\u2019Ulivo remains largely unchanged from the original recipe. Just as its predecessor did, Fiore d\u2019Ulivo takes its inspiration from a staple of the Mediterranean region, the olive tree. Cherished for its practical and symbolic value, and representative of humankind\u2019s connection to nature.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml", "30 ml"], "price_text": "USD 270.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/fiore-dulivo-eau-de-parfum.json", "source_status": "ok", "source_id": "7403747999834", "match_hint": "Xerjoff Fiore D\u2019ulivo", "extra": {"handle": "fiore-dulivo-eau-de-parfum", "tags": ["Amber", "Basil Leaves", "Benzoin", "Hidden", "Jasmine Absolute", "Lemon Zest", "Lotus Flower", "Musk"], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-fioredulivo-eau-de-parfum-100ml.png?v=1744971183", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-fioredulivo-still.jpg?v=1744971183"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/gibeon-eau-de-parfum", "product_name": "Gibeon", "collection": "New Arrivals", "description": "Soothing, yet curiosity-piquing at the same time, Gibeon is named after a meteorite with a fascinating story. Its prehistoric crash-landing in Namibia scattered iron fragments across the Kalahari desert, and it wasn\u2019t until 1836 that Western scientists first documented it \u2014 but the local Nama people had been crafting spearheads and tools from it for centuries, perhaps even millenia. Through its powdery, ethereal scent, Gibeon reflects the mystique of its meteorite namesake.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["50 ml"], "price_text": "USD 235.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/gibeon-eau-de-parfum.json", "source_status": "ok", "source_id": "7613194240090", "match_hint": "Xerjoff Gibeon", "extra": {"handle": "gibeon-eau-de-parfum", "tags": ["Australian Sandalwood", "Bulgarian Rose", "Cedarwood", "Ceylon Cinnamon", "Madagascar Vanilla", "Musk", "Neroli", "Singaporean Patchouli", "Tonka Bean", "Tuscan Orris"], "product_type": "Perfume", "vendor": "XJ", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-gibeon-eau-de-parfum-50ml.png?v=1759484406", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-gibeon-still.jpg?v=1768555768"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/gran-ballo-eau-de-parfum", "product_name": "Gran Ballo", "collection": "New Arrivals", "description": "A joyful expression of the innocence of young love, Gran Ballo leads the senses on a waltz around the grand palace. It is inspired by the grandeur of 19th century aristocratic parties attended by young ladies hoping to find their own Prince Charming. An opulent night between youth and womanhood.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml", "30 ml"], "price_text": "USD 270.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/gran-ballo-eau-de-parfum.json", "source_status": "ok", "source_id": "7403751112794", "match_hint": "Xerjoff Gran Ballo", "extra": {"handle": "gran-ballo-eau-de-parfum", "tags": ["Amber", "Caramel", "Gardenia", "Jasmine Sambac", "Mandarin", "Sandalwood", "Vanilla", "Wild Berries"], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-granballo-eau-de-parfum-100ml.png?v=1744969681", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-granballo-still.jpg?v=1744969681"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/italica-au-de-parfum", "product_name": "Italica", "collection": "New Arrivals", "description": "Italica draws its inspiration from the deep well that is Italian culture, and from one ingredient in particular that typifies the culinary and artisanal excellence that the south of the country is known for \u2014 almond paste. This traditional ingredient is instantly recognisable in so many southern Italian dessert delicacies, thanks to the smooth, lactonic sweetness that it imparts. That same luxurious quality is what characterises Italica as a quintessentially Italian \u2014 and deliciously gourmand \u2014 perfume.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml", "30 ml"], "price_text": "USD 300.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/italica-au-de-parfum.json", "source_status": "ok", "source_id": "7403761107034", "match_hint": "Xerjoff Italica", "extra": {"handle": "italica-au-de-parfum", "tags": ["Almond", "Cedarwood", "Milky Notes", "Saffron", "Sandalwood", "Toffee", "Vanilla", "White Musk"], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-italica-eau-de-parfum-100ml.png?v=1744813411", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-italica-still.jpg?v=1744813411"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/kit-casamorati-one", "product_name": "Casamorati Discovery Set I", "collection": "New Arrivals", "description": "With eight intriguing scents in travel-friendly 2ml flacons, Casamorati Discovery Set I takes the senses on a wide-ranging journey through Italian culture and Art Nouveau. From opulent celebrations and dramatic Sicilian dynasties, to aspiring Italian actresses and scented stories of new beginnings, there is an entire olfactory world to explore. Fiero | Lira | Gran Ballo | Levar Del Sole | Bouquet Ideale | Mefisto | Quattro Pizzi | Tempio d'Acqua", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["16 ml"], "price_text": "USD 45.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/kit-casamorati-one.json", "source_status": "ok", "source_id": "7613194174554", "match_hint": "Xerjoff Casamorati Discovery Set I", "extra": {"handle": "kit-casamorati-one", "tags": ["cmSample", "New Arrivals"], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-casamorati-sample-kit1.png?v=1763039481"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/kit-casamorati-two", "product_name": "Casamorati Discovery Set II", "collection": "New Arrivals", "description": "Casamorati Discovery Set II is composed of eight 2ml perfumes, each one drawing on different aspects of Italian culture, in terms of both inspiration and ingredients. Scents that recall classics of the opera, sweet staples of southern Italian desserts, symbolic mediterranean plants and coastal towns where natural beauty and cinematic glamour meet \u2014 an entire olfactory world awaits. Regio | La Tosca | Fiore D'ulivo | Mefisto Gentiluomo | Dama Bianca | 1888 | Dolce Amalfi | Italica", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["16 ml"], "price_text": "USD 45.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/kit-casamorati-two.json", "source_status": "ok", "source_id": "7613194338394", "match_hint": "Xerjoff Casamorati Discovery Set II", "extra": {"handle": "kit-casamorati-two", "tags": ["cmSample", "New Arrivals"], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-casamorati-sample-kit2.png?v=1763039945"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/la-tosca-eau-de-parfum", "product_name": "La Tosca", "collection": "New Arrivals", "description": "Inspired by one of the finest works from master composer Giacomo Puccini, La Tosca is immediately evocative of the splendour of Italian opera. A floral aromatic scent, it seeks to recreate a sense of the era from which it takes its name, when detail was cherished for its inherent beauty.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml", "30 ml"], "price_text": "USD 270.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/la-tosca-eau-de-parfum.json", "source_status": "ok", "source_id": "7403748622426", "match_hint": "Xerjoff La Tosca", "extra": {"handle": "la-tosca-eau-de-parfum", "tags": ["Bulgarian Rose", "Cold-Pressed Italian Lemon", "Green Mandarin", "Madagascar Vanilla", "Patchouli"], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-latosca-eau-de-parfum-100ml.png?v=1744877493", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-latosca-still.jpg?v=1744877493"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/levar-del-sole-eau-de-parfum", "product_name": "Levar Del Sole", "collection": "New Arrivals", "description": "Levar del Sole is symbolic in every aspect, from its name and flacon design to the selectivity of its ingredients \u2014 its top note of Kannauj rose in particular. Kannauj rose petals are harvested by hand just after sunrise, still damp with dew and with their scent at its most intense. The ritualistic nature of this act is a real life demonstration of the beauty that awaits at every new dawn.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml", "30 ml"], "price_text": "USD 270.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/levar-del-sole-eau-de-parfum.json", "source_status": "ok", "source_id": "7403755929690", "match_hint": "Xerjoff Levar Del Sole", "extra": {"handle": "levar-del-sole-eau-de-parfum", "tags": ["Apple", "Benzoin", "Bergamot", "Caramel", "Cardamom", "Green Notes", "Jasmine", "Lemon", "Lily", "Musk", "Oakmoss", "Orange", "Patchouli", "Rose", "Tonka Bean", "Violet"], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-levardelsole-eau-de-parfum-100ml.png?v=1744889606", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-levardelsole-still.jpg?v=1744889606"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/lira-eau-de-parfum", "product_name": "Lira", "collection": "New Arrivals", "description": "Lira is a perfume whose every aspect enchants, from its deliciously tempting scent to its poetic origin story. Its name derives from the Italian word for lyre, the ancient musical instrument which holds great significance in mythology. Lira is based on a perfume originally released by Casamorati in the late 1800s that was created to help a beautiful, aspiring actress realise her dreams. It was intended to make a lasting impression on all those who encountered it, just like the sweet music of the lyre.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml", "30 ml"], "price_text": "USD 270.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/lira-eau-de-parfum.json", "source_status": "ok", "source_id": "7403748687962", "match_hint": "Xerjoff Lira", "extra": {"handle": "lira-eau-de-parfum", "tags": ["Bergamot", "Blood Orange", "Caramel", "Cinnamon", "Gourmand", "Icons", "Jasmine", "Lavender Flowers", "Musk", "Rose", "Vanilla"], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-lira-eau-de-parfum-100ml.png?v=1744970597", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-lira-still.jpg?v=1744970597"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/louis-xv-rose", "product_name": "Louis XV 1722 Ros\u00e9", "collection": "New Arrivals", "description": "Two artisanal crafts influence each other once more in the latest creation from Xerjoff\u2019s collaborative venture with Maison de Venoge. The sophisticated de Venoge Louis XV Ros\u00e9 Champagne \u2014 an exquisite ros\u00e9 blend from the highly reputed champagne house \u2014 served as the muse for Louis XV 1722 Ros\u00e9. Like the gardens of Versailles at sunrise, the scent of Louis XV 1722 Ros\u00e9 is enchantingly bright and crisp. A work of true luxury, the perfume recalls the champagne blend through its sparkling composition of notes and its flacon's pink tint, encapsulating its opulence and timeless allure.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["50 ml"], "price_text": "USD 275.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/louis-xv-rose.json", "source_status": "ok", "source_id": "7479681646682", "match_hint": "Xerjoff Louis XV 1722 Ros\u00e9", "extra": {"handle": "louis-xv-rose", "tags": [], "product_type": "Perfume", "vendor": "XJ", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-Luis-Rose1.png?v=1764068994", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-louisxvrose-still.jpg?v=1771578416"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/mefisto-eau-de-parfum", "product_name": "Mefisto", "collection": "New Arrivals", "description": "With its origins tracing back well over a century, Mefisto is a perfume with timeless appeal. Released in its original guise by Casamorati around the turn of the 20th century, it was created for a female clientele and sold on the promise of its seductive allure. In its modern-day, unisex form, Mefisto retains this allure, as well as its original Italian character \u2014 something that is reflected in its composition.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml", "30 ml"], "price_text": "USD 270.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/mefisto-eau-de-parfum.json", "source_status": "ok", "source_id": "7403761139802", "match_hint": "Xerjoff Mefisto", "extra": {"handle": "mefisto-eau-de-parfum", "tags": ["Amber", "Bergamot", "Calabrian Lemon", "Cedarwood", "Florentine Iris", "Grapefruit", "Icons", "Lavender Flowers", "Musk", "Mysore Sandalwood", "Rose Absolute"], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-mefisto-eau-de-parfum-100ml.png?v=1744892270", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-mefisto-still.jpg?v=1744892270"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/mefistogentiluomo-eau-de-parfum", "product_name": "Mefisto Gentiluomo", "collection": "New Arrivals", "description": "Originally created in 1888 for traditional Italian barbershops, Mefisto Gentiluomo is the ultimate gentlemen's cologne. The clean, cool and fresh qualities of Mefisto Gentiluomo instantly conjure images of straight razors, badger hair brushes and well-lathered shaving cream. A combination of craftsmanship and old-world luxury.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml"], "price_text": "USD 270.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/mefistogentiluomo-eau-de-parfum.json", "source_status": "ok", "source_id": "7403756224602", "match_hint": "Xerjoff Mefisto Gentiluomo", "extra": {"handle": "mefistogentiluomo-eau-de-parfum", "tags": ["Amber", "Bergamot", "Cedarwood", "Grapefruit", "Iris", "Lavender", "Lemon", "Musk", "Rose"], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-mefistogentiluomo-eau-de-parfum-100ml.png?v=1744967715", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-mefistogentiluomo-still.jpg?v=1744967715"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/p13-parfum", "product_name": "P.13 Limited Edition", "collection": "New Arrivals", "description": "The latest releases from the Sketchbook collection explore some of the many ways in which desire manifests itself, with each offering a different perspective on the theme. The flacon of p.13 is deliberately suggestive, designed to allow the mind to wander. Wrapped tightly in a bondage-style cord, this perfume has taboo connotations of lust and control. The seal on the cord can\u2019t simply be opened, it must be broken in order to set the restrained subject free, creating an imbalanced dynamic: the powerless and the powerful. The tantalising crimson perfume, with its white floral scent, is left at the mercy of its owner. Each flacon is individually numbered and a true collector's item.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml"], "price_text": "USD 1100.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/p13-parfum.json", "source_status": "ok", "source_id": "7610860011610", "match_hint": "Xerjoff P.13 Limited Edition", "extra": {"handle": "p13-parfum", "tags": ["Balsam Of Peru", "Bergamot", "Cloves", "Jasmine", "Oakmoss", "Orange Blossom", "Tobacco", "Tuberose", "Turkish Rose", "Vanilla", "Violet"], "product_type": "Perfume", "vendor": "XJ", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-p13-eau-de-parfum-100ml.png?v=1759302521", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-p13-still.jpg?v=1760340945"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/p18-parfum", "product_name": "P.18  Limited Edition", "collection": "New Arrivals", "description": "The latest releases from the Sketchbook collection explore some of the many ways in which desire manifests itself, with each offering a different perspective on the theme. p.18 presents something of a paradox. Its magnetic scent invites you to come closer, but the barbed wire wrapped around its flacon warns of danger. To experience the perfume\u2019s enchanting effects, one must accept the risk that comes with holding it. Like love, p.18 is beauty, but also pain \u2014 its spicy oriental scent will always keep you coming back for more, even if it hurts. Each flacon is individually numbered and a true collector's item.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml"], "price_text": "USD 1200.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/p18-parfum.json", "source_status": "ok", "source_id": "7610860142682", "match_hint": "Xerjoff P.18  Limited Edition", "extra": {"handle": "p18-parfum", "tags": ["Amber", "Bergamot", "Cloves", "Jasmine", "Musk", "Oakmoss", "Turkish Rose", "Vanilla", "Violet"], "product_type": "Perfume", "vendor": "XJ", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-p18-eau-de-parfum-100ml.png?v=1760685537", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-p18-still1.jpg?v=1760707191"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/p70-parfum", "product_name": "P.70 Limited Edition", "collection": "New Arrivals", "description": "The latest releases from the Sketchbook collection explore some of the many ways in which desire manifests itself, with each offering a different perspective on the theme. p.70 is all about possessiveness and the extremes it can drive people to. In this case, locking something up and throwing away the key so that nobody can have it. Confined by the chain and padlock, the perfume is now forbidden, but this only makes it more desirable \u2014 one always wants what they can\u2019t have. Each flacon is individually numbered and a true collector's item.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml"], "price_text": "USD 1300.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/p70-parfum.json", "source_status": "ok", "source_id": "7610860175450", "match_hint": "Xerjoff P.70 Limited Edition", "extra": {"handle": "p70-parfum", "tags": [], "product_type": "Perfume", "vendor": "XJ", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-p70-eau-de-parfum-100ml.png?v=1759311384", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-p70-still.jpg?v=1760707014"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/quattro-pizzi-eau-de-parfum", "product_name": "Quattro Pizzi", "collection": "New Arrivals", "description": "Quattro Pizzi takes its name from an iconic palace in Palermo that was home to one of the city\u2019s most symbolic and prominent families. The scene where a Sicilian dynasty unfolded, a story of wealth, power, secrecy and sin. Quattro Pizzi is an irresistible perfume reminiscent of the Belle \u00c9poque, intertwining elegance, beauty and nobility with seduction and lust, all set against the dramatic coastal backdrop of northern Sicily.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml", "30 ml"], "price_text": "USD 270.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/quattro-pizzi-eau-de-parfum.json", "source_status": "ok", "source_id": "7403760648282", "match_hint": "Xerjoff Quattro Pizzi", "extra": {"handle": "quattro-pizzi-eau-de-parfum", "tags": ["Blonde Leaf Tobacco", "Coconut", "Coriander", "Davana", "Hay", "Pink Pepper", "Rum", "Tonka Bean", "Tuberose"], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-quattropizzi-eau-de-parfum-100ml.png?v=1744893078", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-quattropizzi-still.jpg?v=1744893078"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/regio-eau-de-parfum", "product_name": "Regio", "collection": "New Arrivals", "description": "Regio takes the nose on a voyage to the bergamot tree-lined shores of Calabria, where the sea breeze carries with it a revitalizing freshness, a reprieve from the hot sun. The Calabrian coast is just one stop on this journey of olfactory enlightenment. There are more layers to Regio than one might expect, as the perfume reveals its delightful nuances as time weaves its thread.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml", "30 ml"], "price_text": "USD 270.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/regio-eau-de-parfum.json", "source_status": "ok", "source_id": "7403752489050", "match_hint": "Xerjoff Regio", "extra": {"handle": "regio-eau-de-parfum", "tags": ["Amber", "Basil Leaves", "Benzoin", "Jasmine Absolute", "Lemon Zest", "Lotus Flower", "Musk"], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-regio-eau-de-parfum-100ml.png?v=1744968150", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-regio-still.jpg?v=1744968150"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/sample-kit", "product_name": "Sample Kit", "collection": "New Arrivals", "description": "The Sample Kit offers a gateway to the vast and varied portfolio of Xerjoff perfumes. Choose up to four scents that pique your curiosity and receive a 2ml sample of each, allowing you to acquaint yourself with their character and nuances \u2014 and to discover your new favourites. For every purchase over \u20ac100 (excluding Sample Kits), enjoy a complimentary Sample Kit as Xerjoff's gift to you. With the purchase of one or two Sample Kits, you\u2019ll receive a promotional code equivalent to the value of one kit, redeemable on your next purchase over \u20ac200 within two months. Please note, a maximum of two Sample Kits may be ordered per transaction.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": [], "price_text": "USD 25.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/sample-kit.json", "source_status": "ok", "source_id": "7402202726490", "match_hint": "Xerjoff Sample Kit", "extra": {"handle": "sample-kit", "tags": ["customizable"], "product_type": "Perfume", "vendor": "XJ", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/sampleKitConfezione.png?v=1770370283"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/tempio-acqua-eau-de-parfum", "product_name": "Tempio d'Acqua", "collection": "New Arrivals", "description": "In the hills not far from Parma, Italy, lies a natural spa that is a masterpiece of architecture. It was designed to connect man with the healing properties of nature \u2014 and to serve as a reminder of her abundant beauty. Depictions of blooming flora and fauna interspersed with Greek goddesses adorn the interior walls in a harmonious fusion of Art Nouveau, Art Deco and Far Eastern influences. Vibrantly-coloured stained glass windows filter the sunlight and intricate floral motifs add an extra dimension of tranquility to the already relaxing environment. The spa\u2019s ability to immerse visitors in the beauty of nature \u2014 both physically and visually \u2014 while offering a sensory escape is the inspiration behind Tempio d\u2019Acqua. A perfume that instantly sparks a sense of comfort and connection, inviting the wearer to lose themselves amongst its enchanting notes.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["100 ml", "30 ml"], "price_text": "USD 270.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/tempio-acqua-eau-de-parfum.json", "source_status": "ok", "source_id": "7759152054362", "match_hint": "Xerjoff Tempio d'Acqua", "extra": {"handle": "tempio-acqua-eau-de-parfum", "tags": ["Ambroxan", "Bergamot", "Cistus Oil", "Fennel", "Mahonial", "Mandarin", "Myrrh", "Peach", "Vanilla"], "product_type": "Perfume", "vendor": "CM", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-tempiodacqua-still.png?v=1773650331", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-tempio-acqua-still-1.jpg?v=1773678140"]}}
{"brand_name": "Xerjoff", "official_url": "https://www.xerjoff.com/en-us/products/timeless-set", "product_name": "Timeless Set", "collection": "New Arrivals", "description": "Alexandria II - Erba Pura - Naxos - TORINO21 The Timeless Set unites Xerjoff\u2019s four most-loved perfumes in a set of four miniature flacons. Four enduring scents that stand out from the house\u2019s 20-year history and continue to leave their mark on the world of perfumery, each one revealing a different side of Xerjoff's creativity.", "top_notes": [], "middle_notes": [], "base_notes": [], "key_notes": [], "accord_text": "", "size_options": ["60 ml"], "price_text": "USD 260.00", "release_signal": "new arrivals collection", "source_type": "official_site", "scraped_at": "20260429T042542Z", "raw_html_path": "data/raw/xerjoff/20260429T042542Z/timeless-set.json", "source_status": "ok", "source_id": "7796884963418", "match_hint": "Xerjoff Timeless Set", "extra": {"handle": "timeless-set", "tags": ["New Arrivals"], "product_type": "Perfume", "vendor": "XJ", "images": ["//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-discovery-best-seller.png?v=1772451598", "//cdn.shopify.com/s/files/1/0632/0327/8938/files/listing-xerjoff-timeless-still.jpg?v=1773066509"]}}
